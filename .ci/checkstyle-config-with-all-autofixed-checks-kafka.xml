<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value=".*[/\\]archetype-resources[/\\].*|.*KafkaProducer\.java"/>
    </module>

    <module name="Header">
        <property name="headerFile" value="@WORK_DIR@/kafka-header.txt"/>
    </module>
    <module name="NewlineAtEndOfFile"/>

    <module name="TreeWalker">
        <module name="AnnotationOnSameLine"/>
        <module name="AvoidStarImport"/>
        <module name="ConstructorsDeclarationGrouping"/>
        <module name="EmptyStatement"/>
        <module name="FinalClass"/>
        <module name="FinalLocalVariable"/>
        <module name="HexLiteralCase"/>
        <module name="MissingDeprecated"/>
        <module name="MissingOverride"/>
        <module name="NumericalPrefixesInfixesSuffixesCharacterCase"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>
        <module name="UnusedLocalVariable"/>
        <module name="UpperEll"/>
        <module name="UseEnhancedSwitch"/>
    </module>
</module>
